# Database (local: docker-compose | prod: Railway)
DATABASE_URL="postgresql://iaesmartguide:iaesmartguide@localhost:5432/iaesmartguide"

# API
API_PORT=3001
API_URL="http://localhost:3001"
JWT_SECRET="change-me-in-production"
REVALIDATE_SECRET="change-me-in-production"
SEED_SECRET="change-me-in-production"

# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
VERIFY_TOKEN=
WABA_ID=

# Asaas
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENV=sandbox

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=iaesmartguide-media
R2_PUBLIC_URL=https://pub-SEU-ID.r2.dev

# Google Gemini
GEMINI_API_KEY=

# Next.js (web) — API_URL é lida em runtime no servidor (preferida na Vercel)
API_URL="https://iaesmartguideapi-production.up.railway.app"
NEXT_PUBLIC_API_URL="https://iaesmartguideapi-production.up.railway.app"
NEXT_PUBLIC_ROOT_DOMAIN="iaesmartguide.com.br"
WEB_URL="https://iaesmartguide.com.br"
