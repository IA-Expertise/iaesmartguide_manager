# Database (local: docker-compose | prod: Railway)
DATABASE_URL="postgresql://iaesmartguide:iaesmartguide@localhost:5432/iaesmartguide"

# API
API_PORT=3001
API_URL="http://localhost:3001"
JWT_SECRET="change-me-in-production"
REVALIDATE_SECRET="change-me-in-production"
SEED_SECRET="change-me-in-production"
OPS_PASSWORD="change-me-ops-password"

# Meta WhatsApp Cloud API
# Webhook permanece no Replit (app prefeituras). Replit encaminha POST para Railway:
#   POST {API_URL}/webhooks/whatsapp
#   Header: X-Webhook-Forward-Secret={WHATSAPP_FORWARD_SECRET}
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
WABA_ID=
WHATSAPP_FORWARD_SECRET=
# Ative "true" somente após integrar Asaas (Fase 4). Padrão: cadastro livre para testes.
WHATSAPP_REQUIRE_PAYMENT=false
# Só se webhook apontar direto para Railway (não é o caso com Replit):
VERIFY_TOKEN=

# Asaas
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_ENV=sandbox

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=iaesmartguide-media
R2_PUBLIC_URL=https://pub-SEU-ID.r2.dev

# Google Gemini
GEMINI_API_KEY=

# Planos Free / Premium
PREMIUM_UPGRADE_URL=
PREMIUM_PRICE_LABEL="R$ 49,90"
LIA_WHATSAPP_NUMBER="5519936196154"
NEXT_PUBLIC_LIA_WHATSAPP="5519936196154"

# Next.js (web) — API_URL é lida em runtime no servidor (preferida na Vercel)
API_URL="https://iaesmartguideapi-production.up.railway.app"
NEXT_PUBLIC_API_URL="https://iaesmartguideapi-production.up.railway.app"
NEXT_PUBLIC_ROOT_DOMAIN="iaesmartguide.com.br"
WEB_URL="https://iaesmartguide.com.br"
