{
  "name": "iaesmartguide",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "dotenv -e .env -- npm run dev -w @iaesmartguide/api",
    "dev:web": "dotenv -e .env -- npm run dev -w @iaesmartguide/web",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build -w @iaesmartguide/db && npm run build -w @iaesmartguide/api",
    "build:web": "npm run build -w @iaesmartguide/web",
    "start:api": "npm run start -w @iaesmartguide/api",
    "db:generate": "dotenv -e .env -- npm run generate -w @iaesmartguide/db",
    "db:migrate": "dotenv -e .env -- npm run migrate -w @iaesmartguide/db",
    "db:push": "dotenv -e .env -- npm run push -w @iaesmartguide/db",
    "db:seed": "dotenv -e .env -- npx tsx packages/db/prisma/seed.ts",
    "db:studio": "dotenv -e .env -- npm run studio -w @iaesmartguide/db"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=20"
  }
}
